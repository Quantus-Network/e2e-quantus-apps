<?xml version="1.0" encoding="utf-8"?>
<!--
    Data extraction rules for Android 12+ (API 31+).
    For a cryptocurrency wallet, we disable all backup to prevent:
    1. Seed phrase leakage via cloud backup
    2. Desync between backup (SharedPreferences) and secure storage (Keychain)
       which can cause "phantom wallet" state where accounts exist but mnemonic is gone.
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Disable cloud backup entirely for wallet security -->
        <exclude domain="sharedpref" path="."/>
        <exclude domain="database" path="."/>
        <exclude domain="file" path="."/>
        <exclude domain="external" path="."/>
    </cloud-backup>
    <device-transfer>
        <!-- Disable device-to-device transfer to prevent desync -->
        <exclude domain="sharedpref" path="."/>
        <exclude domain="database" path="."/>
        <exclude domain="file" path="."/>
        <exclude domain="external" path="."/>
    </device-transfer>
</data-extraction-rules>
